# TradeAI backend environment template
# Copy to backend/.env and replace values before running in production.

# Required: 32+ random characters. Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change_me_generate_a_very_long_random_secret

# Optional but strongly recommended for broker credential encryption.
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIALS_ENCRYPTION_KEY=

# MongoDB
MONGO_URL=mongodb://localhost:27017
DB_NAME=tradeai

# CORS
# Use explicit origins in production, for example:
# CORS_ORIGINS=https://your-domain.com,https://app.your-domain.com
CORS_ORIGINS=http://localhost:5173

# Trading safety
# Keep false unless you intentionally enable real broker execution.
LIVE_TRADING_ENABLED=false

# Token lifetimes, in minutes
ACCESS_TTL_MIN=1440
REFRESH_TTL_MIN=43200

# Logging
LOG_LEVEL=INFO

# Optional external APIs
GEMINI_API_KEY=

# Scheduler tuning
ECONOMIC_EVENT_SCAN_INTERVAL_SEC=30
